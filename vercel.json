{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/auth", "destination": "/auth-callback.html" },
    { "source": "/auth/(.*)", "destination": "/auth-callback.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
