# Example environment variables for local development and CI. NEVER commit real values.

# Public (client) - Vite requires VITE_ prefix for client-exposed env vars
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=public-anon-key

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=service-role-key-keep-secret
SUPABASE_URL=https://your-project-ref.supabase.co
DATABASE_URL=postgresql://user:pass@db-host:5432/dbname

# Vercel runtime URL (if used)
# VERCEL_URL or NEXT_PUBLIC_APP_URL can be set by Vercel
